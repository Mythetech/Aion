@using Blazor.Diagrams
@using Blazor.Diagrams.Core.PathGenerators
@using Blazor.Diagrams.Core.Routers
@using Blazor.Diagrams.Options
@using Blazor.Diagrams.Components
@using Blazor.Diagrams.Core.Anchors
@using Blazor.Diagrams.Core.Geometry
@using Blazor.Diagrams.Core.Models
@using Aion.Contracts.Queries
@using Aion.Contracts.Database

@if (Plan == null)
{
    return;
}

@if (_planTree != null)
{
    <div class="plan-visualizer-container">
        <CascadingValue Value="@_diagram" IsFixed="true">
            <DiagramCanvas></DiagramCanvas>
        </CascadingValue>
        <PlanNodeDetail Node="@_selectedNode" OnClose="ClearSelection" />
    </div>
}
else
{
    <pre class="plan-raw-text">@Plan.PlanContent</pre>
}

@code {
    [Parameter] public QueryPlan? Plan { get; set; }
    [Parameter] public DatabaseType DatabaseType { get; set; }

    [Inject] private IDatabaseProviderFactory ProviderFactory { get; set; } = default!;

    private BlazorDiagram _diagram = default!;
    private QueryPlanTree? _planTree;
    private QueryPlanNode? _selectedNode;

    private const int NodeVerticalSpacing = 120;
    private const int NodeHorizontalSpacing = 300;

    private readonly BlazorDiagramOptions _diagramOptions = new()
    {
        AllowMultiSelection = false,
        Zoom = { Enabled = true },
        Links =
        {
            DefaultRouter = new NormalRouter(),
            DefaultPathGenerator = new SmoothPathGenerator()
        },
    };

    protected override void OnInitialized()
    {
        _diagram = new BlazorDiagram(_diagramOptions);
        _diagram.RegisterComponent<PlanNodeModel, PlanNodeWidget>();
    }

    protected override void OnParametersSet()
    {
        if (Plan == null) return;

        _planTree = TryParsePlan();
        if (_planTree != null)
        {
            RenderTree();
        }
    }

    private QueryPlanTree? TryParsePlan()
    {
        var provider = ProviderFactory.GetProvider(DatabaseType);
        if (provider is IQueryPlanParsingProvider planProvider)
        {
            return planProvider.ParsePlan(Plan!);
        }
        return null;
    }

    private void RenderTree()
    {
        _diagram = new BlazorDiagram(_diagramOptions);
        _diagram.RegisterComponent<PlanNodeModel, PlanNodeWidget>();
        _diagram.SelectionChanged += OnSelectionChanged;

        var nodePositions = new Dictionary<QueryPlanNode, PlanNodeModel>();
        LayoutNode(_planTree!.Root, 0, 0, nodePositions);
        ConnectNodes(_planTree.Root, nodePositions);
        _diagram.Refresh();
    }

    private double LayoutNode(
        QueryPlanNode node,
        int depth,
        double xOffset,
        Dictionary<QueryPlanNode, PlanNodeModel> nodePositions)
    {
        if (node.Children.Count == 0)
        {
            var leafModel = CreateDiagramNode(node, xOffset, depth);
            nodePositions[node] = leafModel;
            return xOffset + NodeHorizontalSpacing;
        }

        var startX = xOffset;
        foreach (var child in node.Children)
        {
            xOffset = LayoutNode(child, depth + 1, xOffset, nodePositions);
        }

        var childPositions = node.Children.Select(c => nodePositions[c].Position!.X).ToList();
        var centerX = (childPositions.First() + childPositions.Last()) / 2;

        var model = CreateDiagramNode(node, centerX, depth);
        nodePositions[node] = model;

        return Math.Max(xOffset, startX + NodeHorizontalSpacing);
    }

    private PlanNodeModel CreateDiagramNode(QueryPlanNode node, double x, int depth)
    {
        var relativeCost = _planTree!.TotalCost > 0 ? node.TotalCost / _planTree.TotalCost : 0;
        var position = new Point(x, depth * NodeVerticalSpacing);
        var model = new PlanNodeModel(node, relativeCost, position);
        model.AddPort(PortAlignment.Top);
        model.AddPort(PortAlignment.Bottom);
        _diagram.Nodes.Add(model);
        return model;
    }

    private void ConnectNodes(QueryPlanNode node, Dictionary<QueryPlanNode, PlanNodeModel> nodePositions)
    {
        if (!nodePositions.TryGetValue(node, out var parentModel)) return;

        foreach (var child in node.Children)
        {
            if (!nodePositions.TryGetValue(child, out var childModel)) continue;

            var sourceAnchor = new SinglePortAnchor(parentModel.GetPort(PortAlignment.Bottom));
            var targetAnchor = new SinglePortAnchor(childModel.GetPort(PortAlignment.Top));
            _diagram.Links.Add(new LinkModel(sourceAnchor, targetAnchor));

            ConnectNodes(child, nodePositions);
        }
    }

    private void OnSelectionChanged(Blazor.Diagrams.Core.Models.Base.SelectableModel model)
    {
        if (model is PlanNodeModel planNode && model.Selected)
        {
            _selectedNode = planNode.PlanNode;
        }
        else
        {
            _selectedNode = null;
        }
        StateHasChanged();
    }

    private void ClearSelection()
    {
        _selectedNode = null;
        StateHasChanged();
    }
}

@inherits LayoutComponentBase
@using Aion.Components.Theme
@using MudBlazor;
@using Mythetech.Framework.Components.AppContextDrawer
@using Mythetech.Framework.Components.Buttons
@using Mythetech.Framework.Infrastructure.MessageBus
@using Aion.Components.Connections
@using Aion.Components.Connections.Commands
@using Aion.Components.History
@using Aion.Components.Querying
@using Aion.Components.Querying.Commands
@using Aion.Contracts.Connections
@using Aion.Components.NativeMenu
@using Aion.Components.Search
@using Aion.Components.Shared.Snackbar
@using Aion.Components.Shared
@using Aion.Components.Shared.Dialogs
@using Aion.Components.Infrastructure
@using Aion.Components.Settings
@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.JSInterop
@using Color = MudBlazor.Color
@using MouseEvent = MudBlazor.MouseEvent
@using Mythetech.Framework.Infrastructure.Initialization
@using Mythetech.Framework.Infrastructure.Plugins
@using Mythetech.Framework.Infrastructure.Settings
@implements IDisposable

<MudThemeProvider @ref="_theme" @bind-IsDarkMode="@AppState.IsDarkMode" Theme="@Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<GlobalCommandSnackbarProvider />
<DialogCommandProvider />
<JsApiCommandProvider />
<FluentKeyCodeProvider />

<MudLayout Class="custom-title-bar-layout">
    <Hermes.Blazor.Components.HermesTitleBar Height="38">
        <div class="aion-title-bar-content" data-hermes-drag>
            <div class="aion-title-bar-spacer"></div>
            <div class="no-drag hermes-no-drag aion-title-bar-search">
                <MudAutocomplete T="SearchModel" Placeholder="Search..." @bind-Value="_search" SearchFunc="@SearchAsync"
                                 @ref="_searchAutocomplete" Variant="Variant.Outlined" Dense="true" ShowProgressIndicator="true"
                                 Margin="Margin.Dense" Clearable="true" Class="rounded-xl aion-search"
                                 OnAdornmentClick="@(async () => await HandleSearch(_search))" InputClass="appbar-narrow-height"
                                 AdornmentIcon="@AionIcons.Search" AdornmentColor="MudBlazor.Color.Primary">
                    <ItemTemplate>
                        <MudStack Class="pa-1" Row="true" AlignItems="AlignItems.Center"
                                  onclick="@(async () => await HandleSearch(context))">
                            <TooltipIcon Size="Size.Small" Text="@(context.Description ?? context.Kind.ToString())"
                                         Icon="@context.Icon" />
                            <MudText>
                                @context
                            </MudText>
                        </MudStack>
                    </ItemTemplate>
                </MudAutocomplete>
            </div>
            <div class="aion-title-bar-spacer"></div>
        </div>
    </Hermes.Blazor.Components.HermesTitleBar>
    <MudDrawer @bind-Open="@AppState.SideBarOpen" Variant="DrawerVariant.Mini" Style="overflow: hidden;">
        <AppContextDrawer @bind-IsOpen="@AppState.SideBarOpen" @bind-ActivePanelId="@_activePanelId"
                          ShowPluginPanels="true" MaxWidth="800">
            <IconBarHeader>
                <AionIconButton Class="p-2 ml-1" Icon="aion-icon" OnClick="@OpenAboutAion" />
                <AionIconButton Class="p-2 ml-1" Icon="@AionIcons.Add" OnClick="AddConnection"
                                Tooltip="Create Connection" />
            </IconBarHeader>

            <PanelNavContent>
                @foreach (var connection in ConnectionState.Connections)
                {
                    <div @oncontextmenu="@(e => ShowConnectionContextMenu(e, connection))"
                         @oncontextmenu:preventDefault="true">
                        <ContextPanelItem Id="@connection.Id.ToString()" Icon="@AionIcons.Connection"
                                          Title="@connection.Name" BadgeColor="@(connection.Active ? Color.Success : Color.Error)">
                            <PanelContent>
                                <ConnectionPanel Connection="@connection" />
                            </PanelContent>
                        </ContextPanelItem>
                    </div>
                }

                <MudDivider DividerType="DividerType.Middle" Class="ml-3" Style="width:60%" />

                <ContextPanelItem Id="history" Icon="@AionIcons.History" Title="History">
                    <PanelContent>
                        <HistoryPanel />
                    </PanelContent>
                </ContextPanelItem>
            </PanelNavContent>

            <PanelFooterContent>
                <MudMenu ActivationEvent="MouseEvent.MouseOver" AnchorOrigin="Origin.TopRight">
                    <ActivatorContent>
                        <MudIconButton Class="ml-1"
                                       Icon="@(AppState.IsDarkMode ? AionIcons.DarkMode : AionIcons.LightMode)"
                                       Color="Color.Primary" Variant="Variant.Text"
                                       OnClick="@(() => AppState.IsDarkMode = !AppState.IsDarkMode)" />
                    </ActivatorContent>
                    <ChildContent>
                        <MudToggleGroup T="string" Size="Size.Small" Value="@SelectedColorMode"
                                        ValueChanged="HandleColorModeChanged" Style="align-items: center">
                            <ToggleIcon Value="light" Icon="@AionIcons.LightMode" Text="Light Mode" />
                            <ToggleIcon Value="dark" Icon="@AionIcons.DarkMode" Text="Dark Mode" />
                            <ToggleIcon Value="system" Icon="@AionIcons.Round("laptop")" Text="System Default" />
                        </MudToggleGroup>
                    </ChildContent>
                </MudMenu>
                <IconButton Class="ml-1" Color="Color.Primary" Icon="@AionIcons.Settings" OnClick="OpenSettingsDialog"
                            Tooltip="Settings" TooltipPlacement="Placement.Right" />
                <MudIconButton Class="ml-1"
                               Icon="@(AppState.SideBarOpen ? AionIcons.CollapseLeft : AionIcons.ExpandRight)"
                               Color="Color.Inherit" OnClick="@(() => AppState.ToggleSideBar())" />
            </PanelFooterContent>
        </AppContextDrawer>

        <MudMenu @ref="_connectionContextMenu" Dense="true" AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopLeft" PositionAtCursor="true">
            <ChildContent>
                <MudMenuItem Icon="@AionIcons.Query" OnClick="ContextMenu_NewQuery">New Query</MudMenuItem>
                <MudMenuItem Icon="@AionIcons.Edit" OnClick="ContextMenu_EditConnection">Edit Connection</MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@AionIcons.Delete" IconColor="Color.Error" OnClick="ContextMenu_DeleteConnection">
                    <MudText Color="Color.Error">Delete Connection</MudText>
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudDrawer>
    <MudMainContent Class="pl-2 pr-0" Style="max-height:100dvh;max-width:100vw;overflow:hidden;">
        <MudContainer Class="px-0 mud-width-full" MaxWidth="MaxWidth.ExtraLarge" Style="height:100%;overflow:hidden;">
            @Body
        </MudContainer>
    </MudMainContent>
    <NativeMenuDispatcher />
    <MenuCommandProvider />
</MudLayout>

@code {
    [Inject] protected GlobalAppState AppState { get; set; } = default!;
    [Inject] protected Microsoft.JSInterop.IJSRuntime JS { get; set; } = default!;
    [Inject] protected SearchService SearchService { get; set; } = default!;
    [Inject] protected SettingsState Settings { get; set; } = default!;
    [Inject] protected PluginState Plugins { get; set; } = default!;
    [Inject] protected IPluginAssetLoader AssetLoader { get; set; } = default!;
    [Inject] protected IAsyncInitializationHost AppInitializer { get; set; } = default!;
    [Inject] protected ConnectionState ConnectionState { get; set; } = default!;
    [Inject] protected MudBlazor.IDialogService DialogService { get; set; } = default!;
    [Inject] protected IMessageBus Bus { get; set; } = default!;
    [Inject] protected QueryState QueryState { get; set; } = default!;

    private SearchModel _search = new();
    private MudAutocomplete<SearchModel>? _searchAutocomplete;
    protected MudThemeProvider _theme { get; set; } = default!;
    private bool _assetsLoaded = false;
    private string? _activePanelId;
    private MudMenu? _connectionContextMenu;
    private ConnectionModel? _contextMenuConnection;

    private string SelectedColorMode => AppState.IsDarkMode ? "dark" : "light";

    private bool _aionInitialized = false;
    private MudTheme Theme { get; } = new AionTheme();

    protected override void OnInitialized()
    {
        AppState.OnDarkModeChanged += HandleDarkModeChange;
        Settings.SettingsChanged += HandleSettingsChanged;
        Plugins.StateChanged += OnPluginStateChanged;
        ConnectionState.ConnectionStateChanged += HandleConnectionStateChanged;

        Plugins.PluginsActive = Settings.PluginState;
    }

    private void HandleSettingsChanged(SettingsState s) => StateHasChanged();

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            AppState.SetThemeProvider(_theme);
        }

        base.OnAfterRender(firstRender);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AppInitializer.InitializeAsync();
        }

        if (firstRender || !_assetsLoaded)
        {
            await LoadAllPluginAssetsAsync();
            _assetsLoaded = true;
            StateHasChanged();
        }

        if (firstRender || !_aionInitialized)
        {
            try
            {
                await AppState.SetSystemColorMode();
                await JS.InvokeVoidAsync("aionSplash.hide");
            
                _aionInitialized = true;
            }
            catch
            {
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    protected async void HandleDarkModeChange(bool isDarkMode)
    {
        await Task.Yield();

        try
        {
            await BlazorMonaco.Editor.Global.SetTheme(JS, isDarkMode ? "vs-dark" : "vs");
            StateHasChanged();
        }
        catch
        {
        }
    }

    public void Dispose()
    {
        AppState.OnDarkModeChanged -= HandleDarkModeChange;
        Settings.SettingsChanged -= HandleSettingsChanged;
        Plugins.StateChanged -= OnPluginStateChanged;
        ConnectionState.ConnectionStateChanged -= HandleConnectionStateChanged;
    }

    protected async Task<IEnumerable<SearchModel>> SearchAsync(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return [];

        List<SearchModel> results = [];

        await foreach (var r in SearchService.SearchAsync(value, token))
        {
            results.Add(r);
        }

        return results;
    }

    private async Task HandleSearch(SearchModel result)
    {
        if (result.SearchAction != null)
            await result.SearchAction.Invoke();

        if (_searchAutocomplete != null)
            await _searchAutocomplete.ClearAsync();
    }

    private void OnPluginStateChanged(object? sender, EventArgs e)
    {
        _assetsLoaded = false;
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadAllPluginAssetsAsync()
    {
        foreach (var plugin in Plugins.EnabledPlugins)
        {
            await AssetLoader.LoadPluginAssetsAsync(plugin);
        }
    }

    private void HandleConnectionStateChanged()
    {
        if (_activePanelId != null && !ConnectionState.Connections.Any(c => c.Id.ToString() == _activePanelId))
        {
            _activePanelId = null;
        }

        StateHasChanged();
    }

    protected async Task HandleColorModeChanged(string s)
    {
        if (!AppState.IsDarkMode && s.Equals("light", StringComparison.OrdinalIgnoreCase))
            return;

        AppState.IsDarkMode = s.Equals("dark", StringComparison.OrdinalIgnoreCase) ||
                              s.Equals("system", StringComparison.OrdinalIgnoreCase);

        StateHasChanged();
    }

    protected async Task OpenAboutAion()
    {
        var options = AionDialogs.CreateDefaultOptions();
        var dialog = await DialogService.ShowAsync<AppContextPanel.AboutAion>("About", options);
        await dialog.Result;
    }

    protected async Task AddConnection()
    {
        await Bus.PublishAsync(new PromptCreateConnection());
    }

    protected async Task OpenSettingsDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            BackgroundClass = "aion-dialog",
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = false
        };
        await DialogService.ShowAsync<Settings.SettingsDialog>("Settings", options);
    }

    private async Task ShowConnectionContextMenu(MouseEventArgs e, ConnectionModel connection)
    {
        _contextMenuConnection = connection;
        if (_connectionContextMenu != null)
        {
            await _connectionContextMenu.OpenMenuAsync(e);
        }
    }

    private async Task ContextMenu_NewQuery()
    {
        if (_contextMenuConnection == null) return;
        var query = QueryState.AddQuery("Untitled");
        query.ConnectionId = _contextMenuConnection.Id;
        await Bus.PublishAsync(new FocusQuery(query));
    }

    private async Task ContextMenu_EditConnection()
    {
        if (_contextMenuConnection == null) return;
        var model = new ConnectionDialogModel
        {
            EditingConnectionId = _contextMenuConnection.Id,
            Name = _contextMenuConnection.Name,
            Type = _contextMenuConnection.Type,
            ConnectionString = _contextMenuConnection.ConnectionString,
            SaveCredentials = _contextMenuConnection.SaveCredentials
        };
        await Bus.PublishAsync(new PromptCreateConnection(model));
    }

    private async Task ContextMenu_DeleteConnection()
    {
        if (_contextMenuConnection == null) return;
        await Bus.PublishAsync(new Connections.Commands.DeleteConnection(_contextMenuConnection.Id));
    }
}

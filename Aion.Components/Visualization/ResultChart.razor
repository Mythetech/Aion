@using Aion.Components.Theme

@if (Result is { Labels.Length: > 0 })
{
    <MudStack Spacing="2" Class="h-100">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudText Typo="Typo.subtitle2">
                @Result.Function of @Result.MeasureColumn by @Result.GroupByColumn
            </MudText>
            <MudSpacer />
            <MudSelect T="ChartType"
                       @bind-Value="_chartType"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Style="min-width: 120px;">
                <MudSelectItem T="ChartType" Value="ChartType.Bar">Bar</MudSelectItem>
                <MudSelectItem T="ChartType" Value="ChartType.Pie">Pie</MudSelectItem>
                <MudSelectItem T="ChartType" Value="ChartType.Line">Line</MudSelectItem>
                <MudSelectItem T="ChartType" Value="ChartType.Donut">Donut</MudSelectItem>
            </MudSelect>
        </MudStack>

        <MudChart T="double"
                  ChartType="@_chartType"
                  ChartSeries="@_series"
                  ChartLabels="@Result.Labels"
                  Width="100%"
                  Height="350px" />
    </MudStack>
}
else
{
    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">
        Select a group-by column and measure to visualize results.
    </MudText>
}

@code {
    private ChartType _chartType = ChartType.Bar;
    private List<ChartSeries<double>> _series = [];
    private AggregationResult? _previousResult;

    [Parameter]
    public AggregationResult? Result { get; set; }

    protected override void OnParametersSet()
    {
        if (Result is { Values.Length: > 0 })
        {
            if (!ReferenceEquals(Result, _previousResult))
            {
                _chartType = Result.RecommendedChartType switch
                {
                    ChartTypeRecommendation.Bar => ChartType.Bar,
                    ChartTypeRecommendation.Pie => ChartType.Pie,
                    ChartTypeRecommendation.Line => ChartType.Line,
                    _ => ChartType.Bar
                };
                _previousResult = Result;
            }

            _series =
            [
                new ChartSeries<double>(Result.Values)
                {
                    Name = $"{Result.Function} of {Result.MeasureColumn}"
                }
            ];
        }
        else
        {
            _series = [];
        }
    }
}
